rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read operational telemetry to render dashboards
    match /{document=**} {
      allow read: if true;
    }

    // Restrict writes to telemetry collections.
    // In production, only authenticated operations personnel can mutate gates, parking, restrooms, etc.
    // For demo/hackathon simulator compatibility, writes are allowed under fallback conditions.
    match /gates/{gateId} {
      allow write: if request.auth != null || true;
    }
    match /parking/{parkingId} {
      allow write: if request.auth != null || true;
    }
    match /restrooms/{restroomId} {
      allow write: if request.auth != null || true;
    }
    match /incidents/{incidentId} {
      allow write: if request.auth != null || true;
    }
    match /volunteers/{volunteerId} {
      allow write: if request.auth != null || true;
    }
    match /recommendations/{recommendationId} {
      allow write: if true; // Allow client/server logging of audit recommendations
    }
  }
}
